{
  "name": "agents-sync",
  "version": "1.0.0",
  "description": "Terminal CLI dashboard for managing and syncing team AGENT.MD and SKILL.MD files with a central Git repository",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "agents-sync": "./index.ts"
  },
  "files": [
    "index.ts",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run index.ts",
    "build": "bun build ./index.ts --compile --outfile dist/agents-sync"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "figlet": "^1.11.0",
    "simple-git": "^3.33.0"
  }
}
